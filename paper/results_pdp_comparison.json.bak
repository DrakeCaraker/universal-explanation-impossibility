{
  "experiment": "pdp_stability_comparison",
  "dataset": "breast_cancer",
  "n_models": 50,
  "n_features": 30,
  "n_pairs": 435,
  "flip_threshold": 0.1,
  "xgb_params": {
    "n_estimators": 100,
    "max_depth": 6,
    "learning_rate": 0.1,
    "subsample": 0.8,
    "colsample_bytree": 0.8
  },
  "comparison_table": [
    {
      "method": "TreeSHAP",
      "n_pairs": 435,
      "n_unstable_pairs": 180,
      "pct_unstable": 41.38,
      "max_flip_rate": 0.5,
      "mean_flip_rate": 0.1318
    },
    {
      "method": "Permutation Importance",
      "n_pairs": 435,
      "n_unstable_pairs": 396,
      "pct_unstable": 91.03,
      "max_flip_rate": 0.5,
      "mean_flip_rate": 0.3055
    },
    {
      "method": "Gain-based Importance",
      "n_pairs": 435,
      "n_unstable_pairs": 254,
      "pct_unstable": 58.39,
      "max_flip_rate": 0.5,
      "mean_flip_rate": 0.1989
    }
  ],
  "cross_method_correlations": {
    "TreeSHAP_vs_Permutation": {
      "r": 0.4572,
      "p_value": 7.447714547573643e-24,
      "both_unstable": 175,
      "only_TreeSHAP": 5,
      "only_Permutation": 221
    },
    "TreeSHAP_vs_Gain-based": {
      "r": 0.4904,
      "p_value": 1.0504540921831927e-27,
      "both_unstable": 161,
      "only_TreeSHAP": 19,
      "only_Gain-based": 93
    },
    "Permutation_vs_Gain-based": {
      "r": 0.4147,
      "p_value": 1.6375188478387277e-19,
      "both_unstable": 237,
      "only_Permutation": 159,
      "only_Gain-based": 17
    }
  },
  "finding": "All three methods exhibit ranking instability. The impossibility is structural (Rashomon property), not an artifact of any single attribution method."
}