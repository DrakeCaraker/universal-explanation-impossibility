#!/bin/bash
# Pre-push hook: verify Lean builds and counts are consistent before pushing.
# Activate: git config core.hooksPath .githooks

set -e

echo "=== Pre-push: verifying Lean build ==="
lake build

echo ""
echo "=== Pre-push: checking counts ==="

THEOREMS=$(grep -c '^theorem\|^lemma' DASHImpossibility/*.lean | awk -F: '{s+=$2} END {print s}')
AXIOMS=$(grep -c '^axiom' DASHImpossibility/*.lean | awk -F: '{s+=$2} END {print s}')
SORRY=$(grep -rc 'sorry' DASHImpossibility/*.lean | awk -F: '{s+=$2} END {print s}')

echo "Theorems+lemmas: $THEOREMS"
echo "Axioms:          $AXIOMS"
echo "Sorry:           $SORRY"

if [ "$SORRY" -gt 0 ]; then
    echo ""
    echo "⚠ WARNING: $SORRY sorry found. Confirm this is intentional."
    echo "Files with sorry:"
    grep -rl 'sorry' DASHImpossibility/*.lean
    echo ""
    echo "Push will proceed, but paper claims 0 sorry. Update paper if needed."
fi

# Block large binary files (>10MB)
LARGE_FILES=$(git diff --cached --name-only --diff-filter=ACM | while read f; do
    size=$(wc -c < "$f" 2>/dev/null || echo 0)
    if [ "$size" -gt 10485760 ]; then
        echo "$f ($((size / 1048576))MB)"
    fi
done)

if [ -n "$LARGE_FILES" ]; then
    echo ""
    echo "✗ BLOCKED: Files over 10MB:"
    echo "$LARGE_FILES"
    exit 1
fi

echo ""
echo "✓ Pre-push checks passed"
